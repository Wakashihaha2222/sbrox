# Copy file này thành ".env" rồi điền giá trị thật vào
ATLANTIS_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ngưỡng giá để báo (đơn vị: đồng / 1000 R$)
PRICE_LIMIT=135000

# Ngưỡng tồn kho thấp để báo "sắp hết hàng" (đơn vị: R$)
STOCK_LOW_THRESHOLD=300

# Khi 1 rate đã đạt giá mục tiêu, bot tiếp tục theo dõi rate đó:
# - Stock thay đổi ít nhất bằng số này (R$) thì báo ngay
STOCK_CHANGE_THRESHOLD=1000
# - Nếu stock không đổi, cứ sau bao nhiêu giây thì nhắc lại 1 lần "vẫn còn hàng"
REMINDER_INTERVAL_SECONDS=300

# Khoảng thời gian nghỉ giữa 2 lần check (giây) - chỉ dùng khi chạy liên tục trên Termux
MIN_WAIT_SECONDS=2
MAX_WAIT_SECONDS=4
